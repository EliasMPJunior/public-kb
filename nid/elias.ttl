###  http://kb.elias.eng.br/nid/elias.ttl#InfoBIM
elias:InfoBIM rdf:type owl:NamedIndividual ,
                       foaf:Project ,
                       schema:SoftwareSourceCode ;
              foaf:maker elias:Elias ;
              schema:license "Open Source" ;
              schema:name "InfoBIM Framework" ;
              schema:programmingLanguage "Python" ;
              foaf:homepage "https://infobim.org"^^xsd:anyURI ;
              dcterms:abstract "A modular runtime environment for Engineering Automation that bridges the gap between static BIM data and dynamic AI agents. InfoBIM provides a machine-readable catalog of tools via its Discovery Protocol, turning ad-hoc OpenBIM scripts into a repeatable production line of capabilities. It enables LLMs to orchestrate automated logic checking, IDS-native rules, and descriptive report generation directly from IFC models, acting as the capability engine for BIM automation."@en ,
                               "Um ambiente de execução modular para Automação de Engenharia que preenche a lacuna entre dados BIM estáticos e agentes de IA dinâmicos. O InfoBIM fornece um catálogo de ferramentas legível por máquina através de seu Protocolo de Descoberta, transformando scripts OpenBIM avulsos em uma linha de produção de capacidades reutilizáveis. Ele permite que LLMs orquestrem checagens lógicas automatizadas, regras nativas IDS e geração de relatórios descritivos diretamente de modelos IFC, atuando como o motor de capacidades para a automação BIM."@pt-br .


###  http://kb.elias.eng.br/nid/elias.ttl#eliasmagalhaesbr_gmail
elias:eliasmagalhaesbr_gmail rdf:type owl:NamedIndividual ,
                                      foaf:Email ,
                                      foaf:OnlineAccount ;
                             foaf:mbox "eliasmagalhaesbr@gmail.com" .


