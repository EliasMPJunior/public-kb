elias:Automation_Skills rdf:type owl:NamedIndividual ,
                            bdc_role:SkillGroup ;
                            schema:name "Automação"@pt-br ,
                                            "Automation"@en ;
                            cv:hasSkill [ rdf:type cv:Skill ;
                                            cv:skillName "Python" ;
                                            cv:skillLevel "Advanced" ] ,
