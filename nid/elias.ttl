                                            cv:skillLevel "Advanced" ] ,
                                        [ rdf:type cv:Skill ;
                                            cv:skillName "IfcOpenShell" ;
                                            cv:skillLevel "Advanced" ] ,
                                        [ rdf:type cv:Skill ;
